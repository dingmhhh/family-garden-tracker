# 把这个文件复制一份，改名为 .env，然后填写你自己的值
# .env 文件不会被提交到 GitHub（已加入 .gitignore）

# Supabase 项目 URL，在 Supabase 后台 Settings -> API 中找到，形如：
# https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anon public key，同样在 Settings -> API 中找到（很长一串字符）
VITE_SUPABASE_ANON_KEY=

# 家庭访问密码，用于简单的进入限制（不是真正的账号系统）
VITE_APP_PASSWORD=change-me
